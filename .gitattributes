# ================================================
# Blender MCP - Git Attributes Configuration
# ================================================
# Defines how Git should handle different file types
# ================================================

# ----------------------------------------
# Source Code - Auto detect line endings
# ----------------------------------------
*.py text eol=lf linguist-language=Python
*.pyw text eol=lf
*.pyi text eol=lf

# ----------------------------------------
# Configuration Files
# ----------------------------------------
*.toml text eol=lf linguist-language=TOML
*.yaml text eol=lf linguist-language=YAML
*.yml text eol=lf linguist-language=YAML
*.json text eol=lf linguist-language=JSON
*.ini text eol=lf
*.cfg text eol=lf

# ----------------------------------------
# Documentation
# ----------------------------------------
*.md text eol=lf linguist-language=Markdown
*.txt text eol=lf
*.rst text eol=lf

# ----------------------------------------
# Scripts
# ----------------------------------------
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# ----------------------------------------
# Makefile
# ----------------------------------------
Makefile text eol=lf
makefile text eol=lf

# ----------------------------------------
# Web Files (if any)
# ----------------------------------------
*.html text eol=lf linguist-language=HTML
*.css text eol=lf linguist-language=CSS
*.js text eol=lf linguist-language=JavaScript

# ----------------------------------------
# Binary Files - Do not modify
# ----------------------------------------
*.zip binary
*.tar binary
*.gz binary
*.rar binary
*.7z binary

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Blender Files
*.blend binary
*.blend1 binary
*.blend2 binary

# ----------------------------------------
# Diff behavior
# ----------------------------------------
# Mark certain files as generated to exclude from diff stats
*.lock linguist-generated=true
uv.lock linguist-generated=true

# ----------------------------------------
# Export ignore (files not included in git archive)
# ----------------------------------------
.gitattributes export-ignore
.gitignore export-ignore
.github/ export-ignore
.pytest_cache/ export-ignore
.mypy_cache/ export-ignore
.ruff_cache/ export-ignore
htmlcov/ export-ignore
.coverage export-ignore

# ----------------------------------------
# Merge strategy
# ----------------------------------------
# Automatically resolve conflicts in lock files
*.lock merge=union
uv.lock merge=union
